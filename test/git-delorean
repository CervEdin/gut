#!/usr/bin/env bash
# Integration tests for git-delorean.py
set -u

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DELOREAN="$SCRIPT_DIR/../git-delorean.py"

TMPDIR_ROOT="$(mktemp -d)"
trap 'rm -rf "$TMPDIR_ROOT"' EXIT

setup_repo() {
    local dir="$TMPDIR_ROOT/$1"
    mkdir -p "$dir"
    git -C "$dir" init -q
    git -C "$dir" config user.email "test@test.com"
    git -C "$dir" config user.name "Test"
    echo "$dir"
}

fail=0

# --- Test 1: Rename + content change (staged) ---
echo -n "rename + content change (staged) ... "
repo="$(setup_repo t1)"
printf "line one\nline two\nline three\nline four\n" > "$repo/old.txt"
git -C "$repo" add old.txt
git -C "$repo" commit -q -m "initial"
mv "$repo/old.txt" "$repo/new.txt"
printf "line one\nline two MODIFIED\nline three\nline four\n" > "$repo/new.txt"
git -C "$repo" add old.txt new.txt
output="$(cd "$repo" && python3 "$DELOREAN" --staged 2>/dev/null)" || true
if echo "$output" | grep -q "old.txt => new.txt"; then
    echo "OK"
else
    echo "FAIL: $output"
    fail=1
fi

# --- Test 2: Pure modification (staged) ---
echo -n "pure modification (staged) ... "
repo="$(setup_repo t2)"
echo "line one" > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m "initial"
echo "line one modified" > "$repo/file.txt"
git -C "$repo" add file.txt
output="$(cd "$repo" && python3 "$DELOREAN" --staged 2>/dev/null)" || true
if echo "$output" | grep -q "file.txt" && ! echo "$output" | grep -q "=>"; then
    echo "OK"
else
    echo "FAIL: $output"
    fail=1
fi

# --- Test 3: Pure rename, no content change (staged) ---
echo -n "pure rename, no content (staged) ... "
repo="$(setup_repo t3)"
printf "line one\nline two\nline three\nline four\n" > "$repo/old.txt"
git -C "$repo" add old.txt
git -C "$repo" commit -q -m "initial"
git -C "$repo" mv old.txt new.txt
output="$(cd "$repo" && python3 "$DELOREAN" --staged 2>/dev/null)" || true
if [ -z "$output" ]; then
    echo "OK"
else
    echo "FAIL: $output"
    fail=1
fi

# --- Test 4: Rename + content change (committed) ---
echo -n "rename + content change (committed) ... "
repo="$(setup_repo t4)"
printf "line one\nline two\nline three\nline four\n" > "$repo/old.txt"
git -C "$repo" add old.txt
git -C "$repo" commit -q -m "initial"
mv "$repo/old.txt" "$repo/new.txt"
printf "line one\nline two MODIFIED\nline three\nline four\n" > "$repo/new.txt"
git -C "$repo" add old.txt new.txt
git -C "$repo" commit -q -m "rename with edits"
output="$(cd "$repo" && python3 "$DELOREAN" HEAD 2>/dev/null)" || true
if echo "$output" | grep -q "old.txt => new.txt"; then
    echo "OK"
else
    echo "FAIL: $output"
    fail=1
fi

# --- Test 5: Range B..C targets B ---
echo -n "range B..C targets B ... "
repo="$(setup_repo t5)"
printf "line one\nline two\nline three\nline four\n" > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m "A: initial"
printf "line one\nline two MODIFIED\nline three\nline four\n" > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m "B: modify line two"
B="$(git -C "$repo" rev-parse HEAD)"
printf "line one\nline two AGAIN\nline three\nline four\n" > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m "C: modify line two again"
C="$(git -C "$repo" rev-parse HEAD)"
output="$(cd "$repo" && python3 "$DELOREAN" "$B..$C" 2>/dev/null)" || true
B_short="$(git -C "$repo" rev-parse --short "$B")"
if echo "$output" | grep -q "$B_short"; then
    echo "OK"
else
    echo "FAIL: expected target $B_short, got: $output"
    fail=1
fi

# --- Test 6: Range A..C targets A ---
echo -n "range A..C targets A ... "
repo="$(setup_repo t6)"
printf "line one\nline two\nline three\nline four\n" > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m "A: initial"
A="$(git -C "$repo" rev-parse HEAD)"
printf "line one\nline two MODIFIED\nline three\nline four\n" > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m "B: modify line two"
printf "line one\nline two AGAIN\nline three\nline four\n" > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m "C: modify line two again"
C="$(git -C "$repo" rev-parse HEAD)"
output="$(cd "$repo" && python3 "$DELOREAN" "$A..$C" 2>/dev/null)" || true
A_short="$(git -C "$repo" rev-parse --short "$A")"
if echo "$output" | grep -q "$A_short"; then
    echo "OK"
else
    echo "FAIL: expected target $A_short, got: $output"
    fail=1
fi

# --- Test 7: --group collapses multi-file targets to first ancestor ---
echo -n "--group collapses targets ... "
repo="$(setup_repo t7)"
printf "aaa\n" > "$repo/a.txt"
printf "bbb\n" > "$repo/b.txt"
git -C "$repo" add a.txt b.txt
git -C "$repo" commit -q -m "A: initial"
printf "aaa MODIFIED\n" > "$repo/a.txt"
git -C "$repo" add a.txt
git -C "$repo" commit -q -m "B: modify a"
B="$(git -C "$repo" rev-parse HEAD)"
# Stage changes to both files — a.txt blames B, b.txt blames A
printf "aaa AGAIN\n" > "$repo/a.txt"
printf "bbb MODIFIED\n" > "$repo/b.txt"
git -C "$repo" add a.txt b.txt
# --staged --group: both files should show B's short hash (first ancestor found)
B_short="$(git -C "$repo" rev-parse --short "$B")"
output="$(cd "$repo" && python3 "$DELOREAN" --staged --group 2>/dev/null)" || true
a_line="$(echo "$output" | grep "^a.txt")"
b_line="$(echo "$output" | grep "^b.txt")"
if echo "$a_line" | grep -q "$B_short" && echo "$b_line" | grep -q "$B_short"; then
    echo "OK"
else
    echo "FAIL: expected both targeting $B_short, got: $output"
    fail=1
fi

# --- Test 8: --fixup --group creates one fixup commit ---
echo -n "--fixup --group creates one fixup ... "
repo="$(setup_repo t8)"
printf "aaa\n" > "$repo/a.txt"
printf "bbb\n" > "$repo/b.txt"
git -C "$repo" add a.txt b.txt
git -C "$repo" commit -q -m "A: initial"
printf "aaa MODIFIED\n" > "$repo/a.txt"
git -C "$repo" add a.txt
git -C "$repo" commit -q -m "B: modify a"
B="$(git -C "$repo" rev-parse HEAD)"
printf "aaa AGAIN\n" > "$repo/a.txt"
printf "bbb MODIFIED\n" > "$repo/b.txt"
git -C "$repo" add a.txt b.txt
(cd "$repo" && python3 "$DELOREAN" --fixup --group 2>/dev/null) || true
fixup_count="$(git -C "$repo" log --oneline | grep -c "^.*fixup")"
if [ "$fixup_count" -eq 1 ]; then
    echo "OK"
else
    echo "FAIL: expected 1 fixup commit, got $fixup_count"
    fail=1
fi

exit "$fail"
